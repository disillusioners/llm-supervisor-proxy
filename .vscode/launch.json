{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Proxy",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/main.go",
            "env": {
                "UPSTREAM_URL": "http://litellm-service.litellm.svc.cluster.local:4000",
                "PORT": "4321",
                "IDLE_TIMEOUT": "90s",
                "MAX_GENERATION_TIME": "600s",
                "MAX_RETRIES": "2"
            }
        }
    ]
}
